#cloud-config
manage_resolv_conf: false
timezone: Europe/Berlin
keyboard:
  model: pc105
  layout: "de"
users:
- name: administrator
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$oZaGVZZBpkaIDJrAlUYAk.$mEKVw.pgCLa39z/0N7y.7FIjHuf6KYpuHiCQw1hGlr1"
enable_ssh: true
ssh_pwauth: true

rpi:
  interfaces:
    serial: true

# 1. System aktualisieren und Software installieren.
package_update: true
packages:
  - freerdp2-x11
  - yad
  - wget

# 2. Befehle ausführen, sobald die Pakete installiert sind
runcmd:
  - [ rfkill, unblock, wifi ]
  - [ sh, -c, "for f in /var/lib/systemd/rfkill/*:wlan; do echo 0 > \"$f\"; done" ]
  # Grafikmodus von Wayland auf X11/Openbox umstellen
  - raspi-config nonint do_wayland W1
  
  # Verzeichnisse für den Benutzer erstellen
  - mkdir -p /home/administrator/kiosk_dateien
  - mkdir -p /home/administrator/.config/autostart
  
  # Deine Dateien herunterladen und ausführbar machen
  - wget -O /home/administrator/kiosk_dateien/rdp.sh "https://github.com/NK-Eyefidelity/RaspiRDP/blob/0fcc80bd5032324ca8af66ca0c7c2638352e6a6d/rdp.sh"
  - wget -O /home/administrator/kiosk_dateien/icon.png "https://github.com/NK-Eyefidelity/RaspiRDP/blob/0fcc80bd5032324ca8af66ca0c7c2638352e6a6d/eye.png"
  - chmod +x /home/administrator/kiosk_dateien/rdp.sh
  
  # Autostart-Eintrag für LXDE/Openbox erstellen
  - |
    cat <<EOF > /home/administrator/.config/autostart/kiosk_autostart.desktop
    [Desktop Entry]
    Type=Application
    Name=KioskAutostart
    Exec=/home/administrator/kiosk_dateien/rdp.sh
    Terminal=false
    EOF
    
  # Zugriffsrechte an deinen Benutzer übergeben
  - chown -R administrator:administrator /home/administrator/kiosk_dateien /home/administrator/.config
  
  # Automatischen Neustart durchführen, um X11 zu aktivieren
  - reboot
