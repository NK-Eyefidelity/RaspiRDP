#cloud-config
manage_resolv_conf: false
timezone: Europe/Berlin
keyboard:
  model: pc105
  layout: "de"
users:
- name: administrator
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$oZaGVZZBpkaIDJrAlUYAk.$mEKVw.pgCLa39z/0N7y.7FIjHuf6KYpuHiCQw1hGlr1"
enable_ssh: true
ssh_pwauth: true

rpi:
  interfaces:
    serial: true

runcmd:
  # 1. Aktiv auf das LAN-Internet warten
  - [ bash, -c, "for ((i=1; i<=45; i++)); do ping -c1 raw.githubusercontent.com >/dev/null 2>&1 && break; sleep 2; done" ]

  - [ rfkill, unblock, wifi ]
  - [ sh, -c, "for f in /var/lib/systemd/rfkill/*:wlan; do echo 0 > \"$f\"; done" ]

  # 2. System aktualisieren und Software installieren (JETZT MIT LXDE)
  - apt-get update
  - DEBIAN_FRONTEND=noninteractive apt-get install -y xserver-xorg x11-xserver-utils openbox lxde lightdm freerdp3-x11 yad wget ca-certificates

  # Erhöhte Wartezeit
  - [ bash, -c, "for ((i=1; i<=45; i++)); do ping -c1 raw.githubusercontent.com >/dev/null 2>&1 && break; sleep 2; done" ]
  
  # Grafikmodus von Wayland auf X11/Openbox umstellen
  - raspi-config nonint do_wayland W1

  # Automatischen GUI-Login (Desktop Autologin) aktivieren
  - raspi-config nonint do_boot_behaviour B4
  - sed -i 's/^#\?autologin-user=.*/autologin-user=administrator/' /etc/lightdm/lightdm.conf

  # LightDM zwingen, in Openbox zu starten (als Kiosk-Unterbau)
  - sed -i 's/^#\?user-session=.*/user-session=default/' /etc/lightdm/lightdm.conf
  - sed -i 's/^autologin-session=.*/autologin-session=openbox/' /etc/lightdm/lightdm.conf
  - update-alternatives --set x-session-manager /usr/bin/openbox-session || true
  
  # Verzeichnisse für den Benutzer erstellen
  - mkdir -p /home/administrator/kiosk_dateien
  - mkdir -p /home/administrator/.config/autostart
  
  # Skripte und Icons herunterladen
  - [ sh, -c, "wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/rdp.sh 'https://raw.githubusercontent.com/NK-Eyefidelity/RaspiRDP/refs/heads/main/rdp.sh'" ]
  - [ sh, -c, "wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/icon.png 'https://raw.githubusercontent.com/NK-Eyefidelity/RaspiRDP/main/eye.png'" ]
  
    # Kiosk-Autostart anlegen
  - |
    cat <<'EOF' > /home/administrator/.config/openbox/autostart
    #!/bin/bash
    xset s off
    xset s noblank
    xset -dpms
    
    # Kurz warten, bis der X11 Server komplett bereit ist
    sleep 3
    
    # In den Ordner wechseln und Skript mit Display-Variable starten
    cd /home/administrator/kiosk_dateien
    DISPLAY=:0 ./rdp.sh &
    EOF
    
  # Zugriffsrechte vergeben
  - chmod +x /home/administrator/kiosk_dateien/rdp.sh
  - chmod +x /home/administrator/.config/openbox/autostart
  - chown -R administrator:administrator /home/administrator/kiosk_dateien /home/administrator/.config

# Reboot wenn Fertig
power_state:
  mode: reboot
  message: "Systemkonfiguration abgeschlossen. Neustart wird eingeleitet."
  timeout: 10
  condition: True
