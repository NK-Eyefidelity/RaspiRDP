#cloud-config
manage_resolv_conf: false
timezone: Europe/Berlin
keyboard:
  model: pc105
  layout: "de"
users:
- name: administrator
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$oZaGVZZBpkaIDJrAlUYAk.$mEKVw.pgCLa39z/0N7y.7FIjHuf6KYpuHiCQw1hGlr1"
enable_ssh: true
ssh_pwauth: true

rpi:
  interfaces:
    serial: true

runcmd:
  # 1. Netzwerk abwarten
  - [ bash, -c, "for ((i=1; i<=45; i++)); do ping -c1 raw.githubusercontent.com >/dev/null 2>&1 && break; sleep 2; done" ]
  - [ rfkill, unblock, wifi ]
  - [ sh, -c, "for f in /var/lib/systemd/rfkill/*:wlan; do echo 0 > \"$f\"; done" ]

  # 2. System updaten und Pakete installieren
  - apt-get update
  - DEBIAN_FRONTEND=noninteractive apt-get install -y xserver-xorg x11-xserver-utils openbox lxde lightdm freerdp3-x11 yad wget ca-certificates dos2unix

  # 3. Grafik auf X11 und Autologin einstellen
  - raspi-config nonint do_wayland W1
  - raspi-config nonint do_boot_behaviour B4
  - sed -i 's/^#\?autologin-user=.*/autologin-user=administrator/' /etc/lightdm/lightdm.conf
  - sed -i 's/^#\?autologin-session=.*/autologin-session=lightdm-xsession/' /etc/lightdm/lightdm.conf
  - sed -i 's/^#\?user-session=.*/user-session=lightdm-xsession/' /etc/lightdm/lightdm.conf

  # 4. Verzeichnisse anlegen und Dateien laden
  - mkdir -p /home/administrator/kiosk_dateien
  - [ sh, -c, "wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/rdp.sh 'https://raw.githubusercontent.com/NK-Eyefidelity/RaspiRDP/refs/heads/main/rdp.sh'" ]
  - [ sh, -c, "wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/icon.png 'https://raw.githubusercontent.com/NK-Eyefidelity/RaspiRDP/main/eye.png'" ]
  - sed -i 's/\r$//' /home/administrator/kiosk_dateien/rdp.sh

  # 5. DEN RECHTSKLICK AUF DEM DESKTOP DEAKTIVIEREN
  - mkdir -p /home/administrator/.config/openbox
  - cp /etc/xdg/openbox/rc.xml /home/administrator/.config/openbox/rc.xml
  - sed -i '/<context name="Root">/,/<\/context>/ s/<action name="ShowMenu"><menu>root-menu<\/menu><\/action>//g' /home/administrator/.config/openbox/rc.xml

  # 6. Die .xsession Datei anlegen
  - |
    cat <<'EOF' > /home/administrator/.xsession
    #!/bin/bash
    xset s off
    xset s noblank
    xset -dpms
    
    # Openbox im Hintergrund starten
    openbox &
    OB_PID=$!
    
    # In den Ordner wechseln und Kiosk-Skript starten
    cd /home/administrator/kiosk_dateien
    ./rdp.sh
    
    # Wenn rdp.sh erfolgreich (Admin Login) beendet wird (exit 0):
    if [ $? -eq 0 ]; then
        kill $OB_PID
        exec startlxde
    fi
    EOF

  # 7. Rechte vergeben
  - chmod +x /home/administrator/kiosk_dateien/rdp.sh
  - chmod +x /home/administrator/.xsession
  - chown -R administrator:administrator /home/administrator/

# Reboot wenn Fertig
power_state:
  mode: reboot
  message: "Systemkonfiguration abgeschlossen. Neustart wird eingeleitet."
  timeout: 10
  condition: True
