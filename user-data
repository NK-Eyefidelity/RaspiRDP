#cloud-config
manage_resolv_conf: false
timezone: Europe/Berlin
keyboard:
  model: pc105
  layout: "de"
users:
- name: administrator
  groups: users,adm,dialout,audio,netdev,video,plugdev,cdrom,games,input,gpio,spi,i2c,render,sudo
  shell: /bin/bash
  lock_passwd: false
  passwd: "$y$jB5$oZaGVZZBpkaIDJrAlUYAk.$mEKVw.pgCLa39z/0N7y.7FIjHuf6KYpuHiCQw1hGlr1"
enable_ssh: true
ssh_pwauth: true

rpi:
  interfaces:
    serial: true

# 1. System aktualisieren und Software installieren.
package_update: true
packages:
  - xserver-xorg       # <-- WICHTIG: Stellt den X-Server bereit
  - x11-xserver-utils  # <-- WICHTIG: Stellt xset bereit (wird im rdp.sh/xsession genutzt)
  - openbox            # <-- WICHTIG: Der Window-Manager für den Kiosk
  - lightdm            # <-- WICHTIG: Handhabt den automatischen Login
  - freerdp3-x11       # Das RDP Paket für Trixie
  - yad
  - wget
  - ca-certificates

# 2. Befehle ausführen, sobald die Pakete installiert sind
runcmd:
  - [ rfkill, unblock, wifi ]
  - [ sh, -c, "for f in /var/lib/systemd/rfkill/*:wlan; do echo 0 > \"$f\"; done" ]
  
  # NEU: Erhöhte Wartezeit auf bis zu 90 Sekunden (45 Versuche x 2 Sekunden)
  - [ bash, -c, "for ((i=1; i<=45; i++)); do ping -c1 raw.githubusercontent.com >/dev/null 2>&1 && break; sleep 2; done" ]
  
  # Grafikmodus von Wayland auf X11/Openbox umstellen
  - raspi-config nonint do_wayland W1
  
  # Automatischen GUI-Login (Desktop Autologin) aktivieren
  - raspi-config nonint do_boot_behaviour B4
  - sed -i 's/^#\?autologin-user=.*/autologin-user=administrator/' /etc/lightdm/lightdm.conf
  
  # Verzeichnisse für den Benutzer erstellen
  - mkdir -p /home/administrator/kiosk_dateien
  - mkdir -p /home/administrator/.config/autostart
  
  # NEU: Wget mit automatischem Retry, falls das Netzwerk kurzzeitig abbricht
  - wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/rdp.sh "https://raw.githubusercontent.com/NK-Eyefidelity/RaspiRDP/refs/heads/main/rdp.sh"
  - wget --tries=10 --waitretry=3 --retry-connrefused -O /home/administrator/kiosk_dateien/icon.png "https://github.com/NK-Eyefidelity/RaspiRDP/blob/main/eye.png?raw=true"
  
  # Skript ausführbar machen
  - chmod +x /home/administrator/kiosk_dateien/rdp.sh
  
  # Kiosk-Sitzung (.xsession) erstellen, die den Desktop überspringt
  - |
    cat <<'EOF' > /home/administrator/.xsession
    #!/bin/bash
    xset s off
    xset s noblank
    xset -dpms
    openbox &
    exec /home/administrator/kiosk_dateien/rdp.sh
    EOF
    
  # Zugriffsrechte an deinen Benutzer übergeben
  - chmod +x /home/administrator/.xsession
  - chown -R administrator:administrator /home/administrator/kiosk_dateien /home/administrator/.xsession

# Reboot wenn Fertig
power_state:
  mode: reboot
  message: "Systemkonfiguration abgeschlossen. Neustart wird eingeleitet."
  timeout: 10
    condition: True
